OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# 키가 있으면 FAISS 검색 질의·Answer Relevance가 위 모델로 영문 변환됩니다.

# Streamlit에서 LLM 백엔드를 Gemini로 선택할 때 (Google AI Studio API 키)
GEMINI_API_KEY=
# OpenAI SDK 호환 엔드포인트. 필요 시 Google 문서 기준으로 변경
# GEMINI_OPENAI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-pro
MEDICAL_RAG_GEMINI_AUX_MODEL=gemini-2.5-flash
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# 상대 경로는 프로젝트 루트(settings.py 위치) 기준입니다. (Streamlit cwd와 무관)
MEDICAL_RAG_DATA_DIR=data
MEDICAL_RAG_INDEX_PATH=data/msd_faiss.index
MEDICAL_RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 한글 질문+영문 PDF가 많으면: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MEDICAL_RAG_LOG_LEVEL=INFO
MEDICAL_RAG_CHUNK_MAX_CHARS=500
MEDICAL_RAG_CHUNK_OVERLAP=60
MEDICAL_RAG_TOP_K=2
MEDICAL_RAG_MOCK_CONTEXT_N=1
MEDICAL_RAG_PDF_OCR=true
# Tesseract가 PATH에 없을 때 전체 경로 (예: C:/Program Files/Tesseract-OCR/tesseract.exe)
MEDICAL_RAG_TESSERACT_EXE=

# Self-Corrective RAG·RAGAS (docs/PIPELINE.md)
MEDICAL_RAG_MAX_LOOPS=3
MEDICAL_RAG_FAITHFULNESS_THRESHOLD=0.8
MEDICAL_RAG_AR_THRESHOLD=0.8
MEDICAL_RAG_CP_THRESHOLD=0.8
MEDICAL_RAG_CRITICAL_AR_THRESHOLD=0.3
MEDICAL_RAG_CRITICAL_F_THRESHOLD=0.3
MEDICAL_RAG_CRITICAL_CP_THRESHOLD=0.2
MEDICAL_RAG_RAGAS_STRICTNESS=3
MEDICAL_RAG_RAGAS_ANSWER_MAX_CHARS=1500
MEDICAL_RAG_RAGAS_CONTEXT_MAX_CHARS=2000
MEDICAL_RAG_RAGAS_LLM_MAX_TOKENS=8192
MEDICAL_RAG_WEB_SEARCH_MAX_RESULTS=3
